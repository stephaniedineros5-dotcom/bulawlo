<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>For Bulawlo</title>

<style>
@import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500&display=swap');

body {
    margin: 0;
    height: 100vh;
    font-family: 'Poppins', sans-serif;
    background: linear-gradient(135deg, #1e1e2f, #2a2a40, #3a3a5a);
    background-size: 400% 400%;
    animation: bgMove 12s ease infinite;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
}

@keyframes bgMove {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

/* intro screen */
.intro {
    position: absolute;
    text-align: center;
    color: white;
    animation: fadeIn 1.5s ease;
}

.intro h1 {
    font-weight: 400;
    letter-spacing: 1px;
}

.intro button {
    margin-top: 20px;
    padding: 12px 30px;
    border-radius: 30px;
    border: none;
    background: white;
    color: #222;
    cursor: pointer;
    transition: 0.3s;
}

.intro button:hover {
    transform: scale(1.05);
}

/* card hidden initially */
.card {
    display: none;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.15);
    backdrop-filter: blur(18px);
    border-radius: 18px;
    padding: 40px 30px;
    width: 320px;
    text-align: center;
    color: #fff;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
}

h2 {
    font-weight: 500;
}

#text {
    margin-top: 15px;
    font-size: 15px;
    color: #dcdcdc;
    min-height: 70px;
}

/* button */
.mainBtn {
    margin-top: 25px;
    padding: 12px 28px;
    border-radius: 30px;
    border: none;
    background: linear-gradient(135deg, #ffffff, #dcdcdc);
    color: #222;
    cursor: pointer;
    transition: 0.3s;
}

.mainBtn:hover {
    transform: translateY(-2px);
}

/* hidden message */
#secret {
    margin-top: 20px;
    font-size: 14px;
    color: #bbbbbb;
    opacity: 0;
    transition: 0.6s ease;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}
</style>
</head>

<body>

<!-- intro -->
<div class="intro" id="intro">
    <h1>Hey Bulawlo</h1>
    <p>There's something I want you to see.</p>
    <button onclick="start()">Open</button>
</div>

<!-- main card -->
<div class="card" id="card">
    <h2>Bulawlo</h2>
    <p id="text"></p>
    <button class="mainBtn" onclick="reveal()">Read this</button>
    <p id="secret">
        I like having you around.  
        Things just feel a little easier, a little better… and I guess that says a lot.
    </p>
</div>

<script>
function start(){
    document.getElementById("intro").style.display = "none";
    document.getElementById("card").style.display = "block";
    typeEffect();
}

const message = "I don’t usually say things like this… but I just felt like you should know.";
let i = 0;

function typeEffect() {
    if (i < message.length) {
        document.getElementById("text").innerHTML += message.charAt(i);
        i++;
        setTimeout(typeEffect, 45);
    }
}

function reveal() {
    document.getElementById("secret").style.opacity = "1";
}
</script>

</body>
</html>
